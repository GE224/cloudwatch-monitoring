        ],
        "period": 300,
        "stat": "Average",
        "view": "timeSeries",
        "annotations": {
          "horizontal": [
            { "label": "High memory threshold", "value": 80 }
          ]
        }
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 6,
      "width": 12,
      "height": 6,
      "properties": {
